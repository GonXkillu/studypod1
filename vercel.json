{
  "version": 2,
  "buildCommand": "npm install -g pnpm && pnpm install && pnpm --filter @workspace/api-server run build",
  "functions": {
    "api/index.mjs": {
      "includeFiles": "api/public/**",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}

