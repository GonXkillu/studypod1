{
  "version": 2,
  "buildCommand": "npm install -g pnpm && pnpm install && pnpm --filter @workspace/api-server run build",
  "outputDirectory": ".",
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "includeFiles": "artifacts/api-server/public/**",
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/artifacts/api-server/dist/index.mjs" }
  ]
}
